{
  "name": "safeher",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered women's cyber safety platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --workspace client -- --host 127.0.0.1",
    "server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
